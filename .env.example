# ──────────────────────────────────────────────────────────
# Maison Éclat – Environment Configuration
# ──────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values you need.
# All variables have safe defaults — the app runs without any
# .env file (mock providers, SQLite DB, debug mode).
# ──────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────
# Default: SQLite file in project root (local dev).
# Production: postgresql+asyncpg://user:pass@host:5432/dbname
# DATABASE_URL=sqlite+aiosqlite:///salon.db

# ── App ───────────────────────────────────────────────────
# DEBUG=true
# APP_VERSION=0.1.0

# ── Speech-to-Text (STT) Provider ────────────────────────
# Supported: "mock" (default), "deepgram"
# When set to a real provider, the matching API key MUST be
# provided.  If the key is empty the app falls back to mock
# automatically — CI / local dev never breaks.
#
# STT_PROVIDER=mock
# STT_API_KEY=your-deepgram-api-key-here
# STT_MODEL=nova-2                # Deepgram model (optional)

# ── Text-to-Speech (TTS) Provider ────────────────────────
# Supported: "mock" (default), "elevenlabs"
# Same fallback logic as STT.
#
# TTS_PROVIDER=mock
# TTS_API_KEY=your-elevenlabs-api-key-here
# TTS_VOICE_ID=EXAVITQu4vr4xnSDxMaL  # ElevenLabs voice ID (optional)
# TTS_MODEL=eleven_multilingual_v2     # ElevenLabs model (optional)

# ── LLM Provider (Pilot wiring) ─────────────────────────────
# Current intent engine is still rule-based; these vars prepare
# OpenAI/GPT runtime wiring.
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# ── Security / Hardening (Phase 4.3) ───────────────────────
# Optional API key for voice endpoints.  When empty (default),
# auth is disabled — convenient for local dev / CI.
# Set to a non-empty string to require X-API-Key header.
#
# VOICE_API_KEY=
# VOICE_API_KEY=my-secret-api-key

# In-memory rate limit for voice endpoints (requests per minute
# per client IP).  0 = disabled.  Default: 60.
#
# RATE_LIMIT_PER_MINUTE=60

# ── Provider Smoke Test (Phase 5.1) ──────────────────────
# Set to "1" to enable real-provider smoke tests in CI.
# Default: unset (all smoke tests are skipped).
#
# SMOKE_TEST_PROVIDERS=1

# ── Telephony Integration (Phase 5.3) ──────────────────────
# Gate: enable/disable all telephony event ingestion.
# TELEPHONY_ENABLED=false
# TELEPHONY_DRY_RUN=true
# TELEPHONY_PROVIDER=local          # local|twilio|vapi
# TELEPHONY_WEBHOOK_SECRET=
# TELEPHONY_MAX_PAYLOAD_BYTES=256000
# TELEPHONY_EVENT_TTL_HOURS=24

# ── Phase 5.4: Pilot Real-Call Flow ────────────────────────
# Twilio webhook URL for real signature verification.
# Must match the URL configured in the Twilio console.
# TWILIO_WEBHOOK_URL=https://yourdomain.com/api/v1/telephony/inbound

# Shadow mode: process events fully but suppress booking-mutating
# DB writes (creation/modification/cancel).  Decision traces are
# persisted for operator review.  Stricter than DRY_RUN.
# TELEPHONY_SHADOW_MODE=true

# ── Redis (optional, Phase 5.4) ─────────────────────────────
# When set, the idempotency guard uses Redis instead of in-memory.
# Install extra: pip install 'vocal-salon-api[redis]'
# REDIS_URL=redis://localhost:6379/0
# REDIS_KEY_PREFIX=salon:idem:
# REDIS_IDEMPOTENCY_TTL_SECONDS=86400

# ── Quick-start examples ─────────────────────────────────
#
# 1) Local dev (default — no changes needed):
#    Just run `uvicorn app.main:app --reload`
#
# 2) Enable Deepgram STT only:
#    STT_PROVIDER=deepgram
#    STT_API_KEY=dg_live_xxxxxxxxxxxx
#
# 3) Enable ElevenLabs TTS only:
#    TTS_PROVIDER=elevenlabs
#    TTS_API_KEY=sk_xxxxxxxxxxxx
#
# 4) Both real providers:
#    STT_PROVIDER=deepgram
#    STT_API_KEY=dg_live_xxxxxxxxxxxx
#    TTS_PROVIDER=elevenlabs
#    TTS_API_KEY=sk_xxxxxxxxxxxx
#
# 5) Enable API key auth for voice endpoints:
#    VOICE_API_KEY=my-secret-api-key
#
# 6) Rate-limit voice endpoints to 30 req/min:
#    RATE_LIMIT_PER_MINUTE=30
